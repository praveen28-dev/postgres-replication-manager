# PostgreSQL Replication Manager Environment Configuration
# PRIMARY DATABASE CONFIGURATION

# Primary PostgreSQL host
# Use 'host.docker.internal' when running in Docker on Windows/Mac
# Use actual IP or hostname for Linux
PRIMARY_HOST=host.docker.internal

# Primary PostgreSQL port
PRIMARY_PORT=5432

# Primary container name (for Docker operations)
PRIMARY_CONTAINER=postgres-primary

# REPLICATION USER CONFIGURATION

# PostgreSQL replication user
REPLICATION_USER=replicator

# Replication user password (CHANGE IN PRODUCTION!)
REPLICATION_PASSWORD=your_secure_password_here


# REPLICA CONFIGURATION

# Replica container name
REPLICA_CONTAINER=postgres-replica

# Replica data directory (inside container)
DATA_DIRECTORY=/var/lib/postgresql/data

# Replica port (host port mapping)
REPLICA_PORT=7777

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================

# Backup timeout in seconds (default: 1 hour)
BACKUP_TIMEOUT=3600

# Number of retry attempts for pg_basebackup
RETRY_ATTEMPTS=5

# Delay between retries in seconds
RETRY_DELAY=10

# =============================================================================
# HEALTH CHECK CONFIGURATION
# =============================================================================

# Timeout for health checks in seconds
HEALTH_CHECK_TIMEOUT=60

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable Prometheus metrics endpoint
METRICS_ENABLED=false

# Metrics endpoint port
METRICS_PORT=8080

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================

# Docker host (leave empty for default)
# DOCKER_HOST=unix:///var/run/docker.sock

# Use Docker SDK (true) or subprocess (false)
USE_DOCKER_SDK=true
